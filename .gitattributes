# 二进制文件标记，避免 git diff 噪音和 CRLF 转换
*.docx binary
*.doc  binary
*.xlsx binary
*.xls  binary
*.pptx binary
*.ppt  binary
*.pdf  binary
*.psd  binary
*.ai   binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.zip  binary
*.tar  binary
*.gz   binary

# 强制 LF，避免 Windows/Linux 行尾混乱
*.md   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.txt  text eol=lf
*.py   text eol=lf
